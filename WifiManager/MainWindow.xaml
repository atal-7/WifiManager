<Window x:Class="WifiManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WifiManager"
        xmlns:vm="clr-namespace:WifiManager.ViewModel"
        mc:Ignorable="d"
        Title="MainWindow" 
        WindowStyle="None"
        AllowsTransparency="True"
        MinWidth="400" MinHeight="350"
        ResizeMode="CanResizeWithGrip"
        Height="450" Width="800">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisConverter"/>
        
        <Style TargetType="Grid">
            <Setter Property="Background" Value="#0e0e0e"/>
        </Style>

        <Style TargetType="TextBlock" x:Key="{x:Type TextBlock}">
            <Setter Property="FontFamily" Value="Arial"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style TargetType="Button" x:Key="{x:Type Button}">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="0" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" TextElement.FontWeight="{TemplateBinding FontWeight}" TextElement.Foreground="{TemplateBinding Foreground}" TextElement.FontSize="{TemplateBinding FontSize}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger  Property="Tag" Value="Close">
                                <Setter Property="CornerRadius" TargetName="border" Value="40"/>
                                <Setter Property="Width" Value="40"/>
                                <Setter Property="Height" Value="40"/>
                                <Setter Property="Margin" Value="10"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="Tag" Value="Close"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter Property="Height" Value="42"/>
                                    <Setter Property="Width" Value="42"/>
                                    <Setter Property="Margin" Value="8"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ToggleButton" x:Key="{x:Type ToggleButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border BorderThickness="1" BorderBrush="Gray" Background="Transparent">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition/>
                                    <ColumnDefinition/>
                                </Grid.ColumnDefinitions>

                                <Border x:Name="UnSelect" Background="#1a9beb" Visibility="Collapsed">
                                    <TextBlock Text="Off" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <Border x:Name="Select" Grid.Column="1" Background="#1a9beb" Visibility="Collapsed">
                                    <TextBlock Text="On" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Visibility" Value="Visible" TargetName="Select"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter Property="Visibility" Value="Visible" TargetName="UnSelect"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ListBoxItem" x:Key="WifiListItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border BorderBrush="Gray" BorderThickness="1" Background="#323232" Padding="15" Margin="10">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition/>
                                    <RowDefinition/>
                                </Grid.RowDefinitions>

                                <ContentPresenter TextElement.Foreground="White" TextElement.FontSize="20"/>
                                <Grid Grid.Row="1" Visibility="Hidden" Name="InputGrid">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="4"/>
                                        <ColumnDefinition Width="auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox FontSize="16" Name="PasswordTextBox" Text="{Binding UpdateSourceTrigger=PropertyChanged, Path=DataContext.PasswordText, Mode=TwoWay, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}"/>
                                    <Button Grid.Column="2" Content="Y" Width="20" Height="20" FontSize="12" Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}, Path=DataContext.ConnectNetworkCommand}" CommandParameter="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=ListBoxItem}, Path=Content.Ssid}"/>
                                </Grid>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Visibility" Value="Visible" TargetName="InputGrid"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button" x:Key="RightOption" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#323232"/>
            <Setter Property="Padding" Value="10 5"/>
            <Setter Property="Margin" Value="5 18"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

        <Style TargetType="ListBoxItem" x:Key="LISTBOX_ITEM_BASE">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" Padding="{TemplateBinding Padding}">
                            <Grid>
                                <ContentPresenter x:Name="ContentPresenter" TextElement.Foreground="{TemplateBinding Foreground}" TextElement.FontSize="{TemplateBinding FontSize}"/>

                                <Border x:Name="LeftOptionSelection" Width="3" Background="#199cec" HorizontalAlignment="Right" Margin="0 -10 -10 -10" Visibility="Collapsed"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="Tag" Value="LeftOption"/>
                                </MultiTrigger.Conditions>
                                <MultiTrigger.Setters>
                                    <Setter Property="Visibility" Value="Visible" TargetName="LeftOptionSelection"/>
                                </MultiTrigger.Setters>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LeftOptions" BasedOn="{StaticResource LISTBOX_ITEM_BASE}" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10"/>
            <Setter  Property="Tag" Value="LeftOption"/>
            <Setter Property="Margin" Value="2 0 2 2"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="#282828"/>
        </Style>
    </Window.Resources>
    
    <WindowChrome.WindowChrome>
        <WindowChrome CornerRadius="4"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Grid Background="#232323" Height="60" PreviewMouseLeftButtonDown="Grid_PreviewMouseLeftButtonDown">
            <Button x:Name="CloseButton" Background="Transparent"  HorizontalAlignment="Right" BorderBrush="White" Click="CloseButton_Click" Panel.ZIndex="5" Tag="Close">
                <TextBlock Text="X" FontSize="28"/>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="0 2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox Name="OptionListBox" Width="170" Background="Transparent" BorderBrush="Transparent" ItemContainerStyle="{StaticResource LeftOptions}" Margin="0 2" SelectedIndex="{Binding SelectedViewIndex, Mode=TwoWay}">
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer>
                            <ItemsPresenter x:Name="ItemPresenter"/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ListBox.Template>
                <ListBoxItem Content="Mobile Hotspot"/>
                <ListBoxItem Content="Wifi"/>
            </ListBox>

            <Grid Background="#191919" Grid.Column="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=OptionListBox, Path=SelectedIndex}" Value="0">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <DockPanel>
                        <ToggleButton 
                            x:Name="WifiEnableSwitch"
                            Width="80" Height="40" 
                            Content="Wifi" 
                            IsChecked="{Binding IsWifiChecked, Mode=TwoWay}"
                            Foreground="White" 
                            FontSize="20" Margin="10 5"/>

                        <ComboBox Width="80" Height="40" Margin="10 5" Background="#323232" SelectedIndex="{Binding SelectedBand, Mode=TwoWay}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center">
                            <ComboBoxItem Content="All (5 Ghz+2.4 Ghz)"/>
                            <ComboBoxItem Content="2.4 Ghz"/>
                            <ComboBoxItem Content="5 Ghz"/>
                        </ComboBox>
                    </DockPanel>
                    <DockPanel Grid.Column="2" Visibility="{Binding ElementName=WifiEnableSwitch, Path=IsChecked, Converter={StaticResource BoolToVisConverter}}">
                        <DockPanel.Resources>
                            <Style TargetType="Button" BasedOn="{StaticResource RightOption}"/>
                        </DockPanel.Resources>
                        <Button Content="Refresh"
                                Command="{Binding WifiEnabledCommand}"/>
                        <Button Content="+ Add"/>
                        <Button Content="Manage"/>
                    </DockPanel>
                </Grid>
                <Border Height="1" Background="Gray" VerticalAlignment="Bottom" Margin="10 0"/>
               
                
                <ListBox 
                    Grid.Row="1" 
                    Visibility="{Binding ElementName=WifiEnableSwitch, Path=IsChecked, Converter={StaticResource BoolToVisConverter}}"
                    Background="Transparent" 
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ItemsSource="{Binding AvailableNetworkList}"
                    ItemContainerStyle="{StaticResource WifiListItem}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Background="Transparent"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Ssid}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
            
            <!--Hotspot View-->
            <Grid Grid.Column="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ElementName=OptionListBox, Path=SelectedIndex}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <Border Background="#191919">
                    <StackPanel HorizontalAlignment="Center" Orientation="Horizontal" VerticalAlignment="Top" Margin="100">
                        <TextBlock Text="Hotspot" Margin="10"/>
                        <ToggleButton 
                            IsChecked="{Binding ToggleHotspot}"
                            Height="40" Width="50">
                        </ToggleButton>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
